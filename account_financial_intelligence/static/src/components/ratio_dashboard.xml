<templates xml:space="preserve">
    <t t-name="account_financial_intelligence.RatioDashboard">
        <div class="p-4 rounded border d-flex justify-content-between align-items-center" 
             t-attf-style="background: {{state.status === 'SOLVENT' ? '#e6fffa' : '#fff5f5'}}; border-left: 5px solid {{state.status === 'SOLVENT' ? '#38b2ac' : '#e53e3e'}} !important;">
            <div>
                <div class="text-uppercase small fw-bold text-muted">Current Ratio (Total Assets / Total Liabs)</div>
                <div class="display-4 fw-bold" style="color: #2d3748;"><t t-esc="state.ratio"/></div>
            </div>
            <div class="text-end">
                <div t-attf-class="badge rounded-pill p-2 px-3 {{state.status === 'SOLVENT' ? 'bg-success' : 'bg-danger'}}">
                    <t t-esc="state.status"/>
                </div>
            </div>
        </div>
    </t>
</templates>
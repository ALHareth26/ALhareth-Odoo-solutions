<odoo>
    <record id="view_nexus_tree" model="ir.ui.view">
        <field name="name">nexus.endpoint.tree</field>
        <field name="model">nexus.endpoint</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'online'" decoration-danger="status == 'offline'">
                <field name="name"/>
                <field name="provider"/>
                <field name="status" widget="badge" decoration-success="status == 'online'"/>
                <field name="health_score" widget="progressbar"/>
            </tree>
        </field>
    </record>

    <record id="view_nexus_form" model="ir.ui.view">
        <field name="name">nexus.endpoint.form</field>
        <field name="model">nexus.endpoint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ping" string="Test Connection" type="object" class="oe_highlight"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Auth">
                            <field name="provider"/>
                            <field name="endpoint_url" widget="url"/>
                            <field name="api_key" password="1"/>
                        </group>
                        <group string="Monitoring">
                            <field name="health_score" widget="gauge" options="{'max': 100}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_nexus_dashboard" model="ir.actions.client">
        <field name="name">Nexus Dashboard</field>
        <field name="tag">boss_nexus.dashboard</field>
    </record>

    <record id="action_nexus_endpoint_act" model="ir.actions.act_window">
        <field name="name">Nexus Nodes</field>
        <field name="res_model">nexus.endpoint</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
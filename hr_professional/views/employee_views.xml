<odoo>
    <record id="view_employee_tree_inherit_hr_prof" model="ir.ui.view">
        <field name="name">hr.employee.tree.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_email']" position="after">
                <field name="employment_date"/>
                <field name="employment_status" widget="badge" decoration-success="employment_status == 'active'" decoration-danger="employment_status == 'terminated'"/>
            </xpath>
        </field>
    </record>

    <record id="view_employee_form_inherit_hr_prof" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="HR Professional (Hareth Malik)">
                    <group>
                        <group string="Employment Dates">
                            <field name="employment_date"/>
                            <field name="end_of_employment"/>
                        </group>
                        <group string="Service Status">
                            <field name="employment_status"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>